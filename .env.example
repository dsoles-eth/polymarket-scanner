# Polymarket Scanner — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Discord ───────────────────────────────────────────────
# Channel ID where the scanner posts opportunity alerts
DISCORD_CHANNEL_SIGNALS=your_discord_channel_id

# Bot token for posting to Discord (keep secret!)
DISCORD_BOT_TOKEN=your_discord_bot_token

# ── Market filters ─────────────────────────────────────────
# Minimum USD liquidity a market must have
MIN_LIQUIDITY=1000

# Skip markets that resolve more than this many days from now
MAX_DAYS_TO_RESOLUTION=90

# Minimum edge (in percentage points) to flag an opportunity
MIN_EDGE_PCT=3

# ── Trading mode ───────────────────────────────────────────
# true  = paper trading (log only, NO real money moved)
# false = live trading (requires exchange integration)
PAPER_TRADING=true

# ── Position sizing ────────────────────────────────────────
# Total capital available for Kelly Criterion sizing (USD)
BANKROLL=1000

# Hard cap: maximum bet as a fraction of bankroll (e.g. 0.05 = 5%)
MAX_KELLY_FRACTION=0.05

# ── Circuit breakers ───────────────────────────────────────
# Pause a market category after this many consecutive losses
MAX_CONSECUTIVE_LOSSES=3
